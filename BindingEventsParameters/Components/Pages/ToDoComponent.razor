@using BindingEventsParameters.Classes
@rendermode InteractiveServer

<ul class="list-group">

    @foreach (var task in Tasks)
    {
        <li class="list-group-item d-flex justify-content-between align-items-center"
            @key="task">

            <!-- LEFT SIDE: Checkbox + Text -->
            <div class="form-check">

                <!-- Two-way binding -->
                <input class="form-check-input"
                       type="checkbox"
                       @bind="task.IsComplete" />

                <!-- Cascading parameter (optional theme color) -->
                <label class="form-check-label ms-2"
                       style="color:@ThemeColor">
                    @task.TaskDescription
                </label>

            </div>

            <!-- RIGHT SIDE: Delete Button -->
            <button class="btn btn-sm btn-danger"
                    @onclick="() => Remove(task)">
                Delete
            </button>

        </li>
    }

</ul>

@code {

    // ===================== PARAMETERS (Parent → Child) =====================

    [Parameter]
    public List<TaskItem> Tasks { get; set; }

    // ===================== EVENT (Child → Parent) =====================

    [Parameter]
    public EventCallback<TaskItem> RemoveTaskChanged { get; set; }

    // ===================== CASCADING PARAMETER =====================

    [CascadingParameter(Name = "ThemeColor")]
    public string ThemeColor { get; set; } = "black";

    // ===================== METHOD CALLED BY PARENT (via @ref optional) =====================

    public void AddNewTask(TaskItem task)
    {
        Tasks.Add(task);
    }

    // ===================== DELETE EVENT =====================

    private async Task Remove(TaskItem task)
    {
        await RemoveTaskChanged.InvokeAsync(task);
    }
}